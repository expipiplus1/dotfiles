From 8768b6234e618cfb7d0cf30d78b203cdcbc96faa Mon Sep 17 00:00:00 2001
From: Ellie Hermaszewska <git@monoid.al>
Date: Tue, 28 Apr 2026 00:31:42 +0800
Subject: [PATCH 5/5] ImagePlatformKWin: emit newScreenshotCanceled when every
 sub-capture is canceled
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

`trackSource(ScreenShotSourceMeta2*, OutputSignal)` aggregates the
per-screen capture results emitted by `ScreenShotSource2`. The lambda
buckets results into `images` (success) and `errorString` (D-Bus
error), then emits `outputSignal` if there are images or
`newScreenshotFailed` if there's an error string. Results with index
`ResultVariant::CanceledState` were silently dropped: a result that's
neither an image nor an error string (i.e. a Cancelled D-Bus reply
from KWin) wouldn't trigger either signal.

If every sub-capture comes back as Cancelled — which can happen if
`ScreenShotManager::takeScreenShot(Output*, ...)` returns
`std::nullopt` for every screen, since that path replies with
`org.kde.KWin.ScreenShot2.Error.Cancelled` — neither completion
signal fires and SpectacleCore waits forever for a result that never
arrives.

Mirror the single-source overload of `trackSource`, which already
emits `newScreenshotCanceled` on a canceled result. This is the
proximate cause of one of the silent-hang flavours of bug 506054
(though the reproducer for that bug actually exercises a different
hang path; see preceding commits).

Bug: https://bugs.kde.org/show_bug.cgi?id=506054
---
 src/Platforms/ImagePlatformKWin.cpp | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/src/Platforms/ImagePlatformKWin.cpp b/src/Platforms/ImagePlatformKWin.cpp
index 4105aae..086f8ba 100644
--- a/src/Platforms/ImagePlatformKWin.cpp
+++ b/src/Platforms/ImagePlatformKWin.cpp
@@ -485,12 +485,15 @@ void ImagePlatformKWin::trackSource(ScreenShotSourceMeta2 *source, OutputSignal
         source->deleteLater();
         QList<QImage> images;
         QString errorString;
+        bool anyCanceled = false;
         for (const auto &result : results) {
             const auto index = result.index();
             if (index == ResultVariant::Image) {
                 images.push_back(std::get<ResultVariant::Image>(result));
             } else if (index == ResultVariant::ErrorString) {
                 errorString.append(std::get<ResultVariant::ErrorString>(result) + u"\n"_s);
+            } else if (index == ResultVariant::CanceledState) {
+                anyCanceled = true;
             }
         }
 
@@ -499,6 +502,14 @@ void ImagePlatformKWin::trackSource(ScreenShotSourceMeta2 *source, OutputSignal
         }
         if (!errorString.isEmpty()) {
             Q_EMIT newScreenshotFailed(errorString);
+        } else if (images.empty() && anyCanceled) {
+            // Every sub-capture was canceled (e.g. KWin replied with
+            // org.kde.KWin.ScreenShot2.Error.Cancelled for every screen
+            // because ScreenShotManager::takeScreenShot() returned
+            // std::nullopt). The single-source overload of trackSource
+            // emits newScreenshotCanceled here; mirror that so
+            // SpectacleCore doesn't hang waiting for a completion signal.
+            Q_EMIT newScreenshotCanceled();
         }
     });
 }
