  9   outputs = { self, nixpkgs, flake-utils }:
 10     flake-utils.lib.eachDefaultSystem (system:
 11       let
 12         pkgs = import nixpkgs {
 13           inherit system;
 14           overlays = [
 15             (final: prev: {
 16               python311 = prev.python311.override {
 17                 packageOverrides = pyFinal: pyPrev: {
 18                   # Fix nixpkgs-unstable test failure in jaraco-test
 19                   jaraco-test = pyPrev.jaraco-test.overridePythonAttrs (old: {
 20                     doCheck = false;
 21                   });
