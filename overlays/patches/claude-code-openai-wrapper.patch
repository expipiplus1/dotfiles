 24                     doCheck = false;
 25                   });
 26                 };
 27               };
 28             })
 29           ];
 30         };
 31         python = pkgs.python311;
 32 
 33 
 34         # Fetch claude-agent-sdk wheel and patch its binary
 35         claude-agent-sdk = python.pkgs.buildPythonPackage rec {
 36           pname = "claude-agent-sdk";
 37           version = "0.1.34";
 38           format = "wheel";
 39 
 40           src = pkgs.fetchurl {
 41             url = "https://files.pythonhosted.org/packages/py3/c/claude_agent_sdk/claude_agent_sdk-${version}-py3-none-manylinux_2_17_x86_64.whl";
 42             sha256 = "sha256-gukUhBDsmP9AYeQ+hWAdjwouhWjYl6uCwyTM8Rwpf8U=";
 43           };
 44 
 45           nativeBuildInputs = [
 46             pkgs.autoPatchelfHook
 47           ];
 48 
 49           buildInputs = [
 50             pkgs.stdenv.cc.cc.lib
 51             pkgs.zlib
 52             pkgs.glibc
 53           ];
 54 
 55           propagatedBuildInputs = with python.pkgs; [
 56             anyio
 57             mcp
 58             typing-extensions
 59           ];
 60 
 61           # The SDK bundles a Node.js binary; allow missing libnode
 62           autoPatchelfIgnoreMissingDeps = [ "libnode.so*" ];
 63 
 64           pythonImportsCheck = [ "claude_agent_sdk" ];
 65         };
 66 
 67         # Build the main application
 68         app = python.pkgs.buildPythonApplication {
 69           pname = "claude-code-openai-wrapper";
 70           version = "2.2.0";
 71           pyproject = true;
 72 
 73           src = ./.;
 74 
 75           nativeBuildInputs = [
 76             python.pkgs.poetry-core
 77             python.pkgs.pythonRelaxDepsHook
 78             pkgs.makeBinaryWrapper
 79           ];
 80 
 81           propagatedBuildInputs = with python.pkgs; [
 82             fastapi
 83             uvicorn
 84             pydantic
 85             python-dotenv
 86             httpx
 87             sse-starlette
 88             python-multipart
 89             slowapi
 90             claude-agent-sdk
 91           ];
 92 
 93           # Skip tests during build (they require network/API access)
 94           doCheck = false;
 95 
 96           # Skip runtime deps check (nixpkgs has newer compatible versions)
 97           pythonRelaxDeps = true;
 98 
 99           # Add Node.js to PATH for external Claude CLI if user installs one
100           # Set CLAUDE_CLI_PATH env var to use a custom CLI instead of bundled one
101           makeWrapperArgs = [
102             "--prefix PATH : ${pkgs.nodejs_20}/bin"
103           ];
104 
105           meta = {
106             description = "OpenAI API-compatible wrapper for Claude Code";
107             homepage = "https://github.com/anthropics/claude-code-openai-wrapper";
108             license = pkgs.lib.licenses.mit;
109             mainProgram = "claude-wrapper";
110           };
111         };
112 
113         # Development shell
114         devShell = pkgs.mkShell {
115           packages = [
116             python
117             pkgs.poetry
118             pkgs.nodejs_20
119           ];
120 
121           buildInputs = [
122             pkgs.stdenv.cc.cc.lib
123             pkgs.zlib
124           ];
125 
126           shellHook = ''
127             echo "Claude Code OpenAI Wrapper development environment"
128             echo "Python: $(python --version)"
129             echo "Poetry: $(poetry --version)"
130             echo ""
131 
132             # Configure poetry to use in-project virtualenv
133             poetry config virtualenvs.in-project true 2>/dev/null || true
134 
135             # Set up library path for claude-agent-sdk binary
136             export LD_LIBRARY_PATH="${pkgs.lib.makeLibraryPath [
137               pkgs.stdenv.cc.cc.lib
138               pkgs.zlib
139               pkgs.glib
140             ]}''${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
141 
142             # Auto-activate venv if it exists
143             if [ -f ".venv/bin/activate" ]; then
144               source .venv/bin/activate
145               echo "Activated existing virtualenv"
146             else
147               echo "Run 'poetry install' to create virtualenv and install dependencies"
148             fi
149 
150             echo "Run 'python -m src.main' to start the server"
151           '';
152         };
153 
154       in {
155         packages = {
156           default = app;
157           claude-wrapper = app;
158         };
159 
160         devShells.default = devShell;
161 
162         apps.default = {
163           type = "app";
164           program = "${app}/bin/claude-wrapper";
165         };
166       }
167     );
168 }
